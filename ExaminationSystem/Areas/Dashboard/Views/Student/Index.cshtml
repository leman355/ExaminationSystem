@model IEnumerable<Students>


<a href="/dashboard/student/create" class="btn btn-outline-primary">Create</a>


<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">students</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>UserName</th>
                        <th>Password</th>
                        <th>Contact</th>
                        <th>Picture</th>
                        <th>Group</th>
                        <th></th>
                    </tr>
                </thead>
                <tfoot>
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>UserName</th>
                        <th>Password</th>
                        <th>Contact</th>
                        <th>Picture</th>
                        <th>Group</th>
                        <th></th>
                    </tr>
                </tfoot>
                <tbody>
                    @foreach (var student in Model)
                    {
                        <tr>
                            <td>@student.Id</td>
                            <td>@student.Name</td>
                            <td>@student.UserName</td>
                            <td>@student.Password</td>
                            <td>@student.Contact</td>
                            <td><img src="@student.Picture" width="200" height="100" /></td>
                            <td>@student.Groups.Name/td>
                            <td class="col-2">
                                <a href="/dashboard/student/edit/@student.Id" class="btn btn-outline-warning">Edit</a>
                                <a href="/dashboard/student/delete/@student.Id" class="btn btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
